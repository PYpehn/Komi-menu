closeButton.MouseButton1Click:Connect(function()
    TweenService:Create(menuFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -(isMobile and 190 or 170), 0.5, -(isMobile and 330 or 330)),
        BackgroundTransparency = 0.15
    }):Play()
    task.wait(0.3)
    menuFrame.Visible = false
    menuFrame.Position = UDim2.new(0.5, -(isMobile and 190 or 170), 0.5, -(isMobile and 300 or 290))
    openButton.Visible = true
    menuOpen = false
    if isMobile and mobileFlyControls then
        mobileFlyControls.Visible = false
    end
end)


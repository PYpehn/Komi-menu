-- Flow Button
local flowButton = createCuteButton(canvas, "🔄 Flow: OFF", UDim2.new(0, 8, 0, yPos), colors.accent)
flowButton.MouseButton1Click:Connect(function()
    if flowActive then
        flowActive = false
        if flowConnection then flowConnection:Disconnect() end
        flowButton.Text = "🔄 Flow: OFF"
        flowButton.BackgroundColor3 = colors.accent
        createNotification("🔄 Flow stopped")
    else
        if #waypoints < 2 then
            createNotification("⚠️ Need at least 2 waypoints!", true)
            return
        end
        flowActive = true
        currentWaypoint = 1
        flowButton.Text = "🔄 Flow: ON"
        flowButton.BackgroundColor3 = colors.success
        createNotification("🔄 Flowing through waypoints...")

        flowConnection = RunService.RenderStepped:Connect(function()
            if not flowActive then
                if flowConnection then flowConnection:Disconnect() end
                return
            end

            local char = player.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end

            local hrp = char:FindFirstChild("HumanoidRootPart")
            local currentPos = hrp.Position
            local targetPos = waypoints[currentWaypoint].position
            local distance = (targetPos - currentPos).Magnitude

            if distance < 5 then
                currentWaypoint = currentWaypoint + 1
                if currentWaypoint > #waypoints then
                    currentWaypoint = 1
                end
            else
                local direction = (targetPos - currentPos).Unit
                local newPos = currentPos + direction * 3
                hrp.CFrame = CFrame.new(newPos)

                if isFlying and bodyVelocity then
                    bodyVelocity.Velocity = direction * flySpeed
                end
            end
        end)
    end
end)
yPos = yPos + (isMobile and 50 or 50)


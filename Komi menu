player.CharacterAdded:Connect(function(newCharacter)
    if isFlying then
        stopFlying()
        cleanupMobileFly()
        flyButton.Text = "✈️ Fly Mode"
        flyButton.BackgroundColor3 = colors.primary
        if isMobile and mobileFlyControls then
            mobileFlyControls.Visible = false
        end
    end
    if flowActive then
        flowActive = false
        if flowConnection then flowConnection:Disconnect() end
        flowButton.Text = "🔄 Flow: OFF"
        flowButton.BackgroundColor3 = colors.accent
    end
    if noclipActive then
        noclipActive = false
        if noclipConnection then noclipConnection:Disconnect() end
        noclipButton.Text = "🌀 Noclip: OFF"
        noclipButton.BackgroundColor3 = colors.accent
    end
    if invisibleActive then
        invisibleActive = false
        invisibleButton.Text = "👻 Invisible: OFF"
        invisibleButton.BackgroundColor3 = colors.secondary
    end
    
    character = newCharacter
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    speedButton.Text = "⚡ Speed: 16"
    speedButton.BackgroundColor3 = colors.success
end)

-- ======================
-- OPEN / CLOSE LOGIC
-- ======================
openButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        openButton.MouseButton1Click:Fire()
    end
end)

openButton.MouseButton1Click:Connect(function()
    menuFrame.Visible = true
    if isMobile then
        menuFrame.Position = UDim2.new(0.075, 0, 0.15, 0)
    else
        menuFrame.Position = UDim2.new(0.5, -180, 0.5, -340)
        TweenService:Create(menuFrame, TweenInfo.new(0.5, Enum.EasingStyle.Bounce), {
            Position = UDim2.new(0.5, -180, 0.5, -300)
        }):Play()
    end
    openButton.Visible = false
    menuOpen = true
end)

closeButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        closeButton.MouseButton1Click:Fire()
    end
end)

closeButton.MouseButton1Click:Connect(function()
    if isMobile then
        menuFrame.Visible = false
    else
        TweenService:Create(menuFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
            Position = UDim2.new(0.5, -180, 0.5, -340)
        }):Play()
        task.wait(0.3)
        menuFrame.Visible = false
        menuFrame.Position = UDim2.new(0.5, -180, 0.5, -300)
    end
    openButton.Visible = true
    menuOpen = false
end)

-- ======================
-- KEYBIND TO TOGGLE MENU
-- ======================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift or input.KeyCode == Enum.KeyCode.LeftShift then
        if menuOpen then
            closeButton.MouseButton1Click:Fire()
        else
            openButton.MouseButton1Click:Fire()
        end
    end
end)

-- Mobile back button support
if isMobile then
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.Back then
            if menuOpen then
                closeButton.MouseButton1Click:Fire()
            end
        end
    end)
end

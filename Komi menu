local function teleportToWaypoint(index)
    if not waypoints[index] then 
        createNotification("⚠️ Waypoint " .. index .. " doesn't exist!", true)
        return 
    end
    local pos = waypoints[index].position
    local char = player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char:FindFirstChild("HumanoidRootPart").CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        createNotification("✨ Teleported to WP " .. index)
    end
end


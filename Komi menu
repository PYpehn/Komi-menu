    local rightFly = createFlyButton("➡️", UDim2.new(0, 170, 0, 60), colors.warning)

    local flyConnections = {}

    local function setupMobileFly(btn, dirFunc)
        local conn
        btn.TouchBegan:Connect(function()
            if not isFlying then return end
            conn = RunService.RenderStepped:Connect(function()
                local dir = dirFunc()
                if dir.Magnitude > 0 and bodyVelocity then
                    bodyVelocity.Velocity = dir.Unit * flySpeed
                end
            end)
        end)
        btn.TouchEnded:Connect(function()
            if conn then
                conn:Disconnect()
                if bodyVelocity then
                    bodyVelocity.Velocity = Vector3.zero
                end
            end
        end)
    end

    setupMobileFly(upFly, function() return Vector3.new(0, 1, 0) end)
    setupMobileFly(downFly, function() return Vector3.new(0, -1, 0) end)
    setupMobileFly(leftFly, function()
        local cam = workspace.CurrentCamera
        return cam and -cam.CFrame.RightVector or Vector3.new(-1, 0, 0)
    end)
    setupMobileFly(rightFly, function()
        local cam = workspace.CurrentCamera
        return cam and cam.CFrame.RightVector or Vector3.new(1, 0, 0)
    end)

    -- Show/hide mobile fly controls
    local function showMobileFlyControls()
        mobileFlyControls.Visible = true
    end

    local function hideMobileFlyControls()
        mobileFlyControls.Visible = false
    end
end


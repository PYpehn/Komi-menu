if isMobile then
    mobileFlyControls = Instance.new("Frame")
    mobileFlyControls.Name = "MobileFlyControls"
    mobileFlyControls.Size = UDim2.new(0, 240, 0, 200)
    mobileFlyControls.Position = UDim2.new(0.5, -120, 0.7, -100)
    mobileFlyControls.BackgroundTransparency = 1
    mobileFlyControls.Visible = false
    mobileFlyControls.ZIndex = 5
    mobileFlyControls.Parent = screenGui

    local function createFlyButton(text, position, color)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 65, 0, 65)
        btn.Position = position
        btn.BackgroundColor3 = color
        btn.BackgroundTransparency = 0.2
        btn.Text = text
        btn.TextColor3 = colors.text
        btn.Font = Enum.Font.IndieFlower
        btn.TextSize = 30
        btn.ZIndex = 5
        btn.Parent = mobileFlyControls
        
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 15)
        corner.Parent = btn
        
        return btn
    end

    local upFly = createFlyButton("⬆️", UDim2.new(0.5, -32.5, 0, 0), colors.primary)
    local downFly = createFlyButton("⬇️", UDim2.new(0.5, -32.5, 0, 130), colors.danger)
    local leftFly = createFlyButton("⬅️", UDim2.new(0, 10, 0, 65), colors.warning)
    local rightFly = createFlyButton("➡️", UDim2.new(0, 165, 0, 65), colors.warning)

    local function setupMobileFly(btn, dirFunc)
        local connection
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                if not isFlying then return end
                if connection then connection:Disconnect() end
                connection = RunService.RenderStepped:Connect(function()
                    if not isFlying or not bodyVelocity then
                        if connection then
                            connection:Disconnect()
                            connection = nil
                        end
                        return
                    end
                    local dir = dirFunc()
                    if dir.Magnitude > 0 then
                        bodyVelocity.Velocity = dir.Unit * flySpeed
                    end
                end)
            end
        end)
        
        btn.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.Touch then
                if connection then
                    connection:Disconnect()
                    connection = nil
                end
                if bodyVelocity then
                    bodyVelocity.Velocity = Vector3.zero
                end
            end
        end)
        
        table.insert(mobileFlyConnections, {
            button = btn,
            disconnect = function()
                if connection then
                    connection:Disconnect()
                    connection = nil
                end
            end
        })
    end

    setupMobileFly(upFly, function() return Vector3.new(0, 1, 0) end)
    setupMobileFly(downFly, function() return Vector3.new(0, -1, 0) end)
    setupMobileFly(leftFly, function()
        local cam = workspace.CurrentCamera
        return cam and -cam.CFrame.RightVector or Vector3.new(-1, 0, 0)
    end)
    setupMobileFly(rightFly, function()
        local cam = workspace.CurrentCamera
        return cam and cam.CFrame.RightVector or Vector3.new(1, 0, 0)
    end)
end

local function cleanupMobileFly()
    if mobileFlyConnections then
        for _, conn in ipairs(mobileFlyConnections) do
            conn.disconnect()
        end
        mobileFlyConnections = {}
    end
end

